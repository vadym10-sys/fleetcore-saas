# FleetCore SaaS environment template
#
# Pilot mode:
# - Leave PRODUCTION=false or unset.
# - The app can run with local PostgreSQL defaults and provider fallbacks.
#
# Commercial production mode:
# - Set PRODUCTION=true.
# - The API will refuse to start if required production variables are missing.

# Runtime
NODE_ENV=development
PRODUCTION=false
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
API_HOST=0.0.0.0
API_PORT=4000

# Database and auth
DATABASE_URL=postgresql://fleetcore@127.0.0.1:5432/fleetcore
JWT_SECRET=replace-with-at-least-32-characters

# Upload limits
MAX_UPLOAD_BYTES=8388608
MAX_UPLOAD_BODY_BYTES=12582912

# Web public config
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/fleetcore-saas/rental-reservation

# AI search
OPENAI_API_KEY=
OPENAI_SEARCH_MODEL=gpt-4.1-mini

# Stripe billing - required when PRODUCTION=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Email delivery - RESEND_API_KEY or SMTP_URL required when PRODUCTION=true
RESEND_API_KEY=
SMTP_URL=

# WhatsApp Business API - required when PRODUCTION=true
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram bot - required when PRODUCTION=true
TELEGRAM_BOT_TOKEN=

# S3-compatible object storage - required when PRODUCTION=true
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Monitoring - one of these is required when PRODUCTION=true
SENTRY_DSN=
MONITORING_DSN=
UPTIME_MONITOR_URL=

# GDPR/legal documentation - required when PRODUCTION=true
PRIVACY_POLICY_URL=
TERMS_URL=
GDPR_DOCS_URL=
