{
  "name": "@fleetcore/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/apps/api/src/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fleetcore/shared": "workspace:*",
    "fastify": "^5.0.0",
    "pg": "^8.13.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
